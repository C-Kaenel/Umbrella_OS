#!/bin/busybox sh

/bin/busybox mount -t proc none /proc
/bin/busybox mount -t sysfs none /sys
/bin/busybox mount -t devtmpfs none /dev

/bin/busybox --install -s /bin

dmesg -n 1

ip link set eth0 up
udhcpc -i eth0 -q -s /etc/udhcpc.script -t 3

clear
echo "================================"
echo "      Welcome to Umbrella OS    "
echo "================================"

exec /bin/busybox setsid /bin/busybox cttyhack /bin/busybox env PS1='UmbrellaOS # ' /bin/sh
